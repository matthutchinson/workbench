# general
fullscreen = true
confirm-close-surface = false
macos-titlebar-style = hidden

# cursor
cursor-style = block

# font
font-family = "BerkeleyMono Nerd Font Plus Font Awesome Plus Font Awesome Extension Plus Octicons"
font-size = 15
adjust-cell-height=16%
font-feature = -calt, -liga, -dlig # disable ligatures

# colors & theme
theme = Iceberg Dark
# bold-is-bright = false
background = 000000
# foreground = E0E0E0

# shaders
custom-shader = shaders/cursor_warp.glsl
